<policies>
    <inbound>
        <!-- 直接呼叫 Entra token endpoint，不 proxy 到 mcp-oauth（避免 APIM self-call 問題） -->
        <!-- token_endpoint_auth_method=none，直接轉送 PKCE token exchange 至 Entra -->
        <set-variable name="requestBody" value="@(context.Request.Body.As&lt;string&gt;(preserveContent: true))" />
        <send-request mode="new" response-variable-name="tokenResp" timeout="30" ignore-error="false">
            <set-url>https://login.microsoftonline.com/{{McpTenantId}}/oauth2/v2.0/token</set-url>
            <set-method>POST</set-method>
            <set-header name="Content-Type" exists-action="override">
                <value>application/x-www-form-urlencoded</value>
            </set-header>
            <set-body>@((string)context.Variables["requestBody"])</set-body>
        </send-request>
        <return-response response-variable-name="tokenResp" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
