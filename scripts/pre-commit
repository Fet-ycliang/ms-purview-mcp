#!/bin/sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "執行 pre-commit unit tests..."

if command -v uv >/dev/null 2>&1; then
  echo "使用 uv 執行 pytest。"
  exec uv run python -m pytest tests/ -m "not e2e" -v --tb=short
fi

PYTHON_CMD=""
if command -v python >/dev/null 2>&1; then
  PYTHON_CMD="python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_CMD="python3"
fi

if [ -n "$PYTHON_CMD" ]; then
  if "$PYTHON_CMD" -m pytest --version >/dev/null 2>&1; then
    echo "使用 $PYTHON_CMD 執行 pytest。"
    exec "$PYTHON_CMD" -m pytest tests/ -m "not e2e" -v --tb=short
  fi

  echo "錯誤: 已找到 $PYTHON_CMD，但目前環境沒有 pytest。請先安裝 dev 依賴，或安裝 uv 後再 commit。" >&2
  exit 1
fi

echo "錯誤: 找不到 uv、python 或 python3，無法在 commit 前執行 unit tests。" >&2
exit 1
