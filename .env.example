# Microsoft Purview runtime identity
PURVIEW_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PURVIEW_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PURVIEW_CLIENT_SECRET=your-purview-client-secret-here
# 相容舊版：若你沿用既有 AZURE_* 變數，程式仍可讀取

# Microsoft Purview
PURVIEW_ACCOUNT_NAME=your-purview-account-name
# Base URL 由 account name 自動組成: https://<account>.purview.azure.com

# Databricks Unity Catalog
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxx
# 或改用 Service Principal:
# DATABRICKS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# DATABRICKS_CLIENT_SECRET=your-databricks-sp-secret
# DATABRICKS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Unity Catalog 設定（可選）
UC_DEFAULT_CATALOG=prod_catalog
# 多 catalog 時用逗號分隔字串
# UC_CATALOGS=prod_catalog,others_catalog
